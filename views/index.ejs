<!DOCTYPE html>
<html lang="fr" data-theme="bureau">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LookuLooku</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚆</text></svg>">

  <%# Polices Google : serif pour Bureau, sans pour Cinéma %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Outfit:wght@400;600&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">

  <script>
    try {
      document.documentElement.setAttribute("data-theme", localStorage.getItem("theme") || "bureau");
    } catch (_) {}
  </script>
  <link rel="stylesheet" href="/styles/main.css">
</head>

<body>

  <%# Bouton de bascule de thème %>
  <header class="header">
    <h1>
      <a href="/" class="logo-link">
        looku<span>•</span>looku
      </a>
    </h1>
    <button class="theme-toggle" aria-label="Changer de thème">🌙</button>
  </header>

  <main id="dashboard-content">
  <% if (locals.erreur) { %>
  <%# Cas d'erreur %>
  <p class="erreur">Oups : <%= erreur %></p>

  <% } else { %>

  <%# === Cartes météo : Trilport grande, Meaux petite === %>
  <% if (meteos && meteos.length === 2) { %>
  <section class="villes">

    <%# Carte principale : Trilport %>
    <article class="carte carte-principale">
      <% if (afficherAlerteCarte) { %>
      <span class="carte-alerte">⚠️</span>
      <% } %>
      <div class="carte-contenu">

        <div class="meteo-info">
          <h2>Trilport</h2>
          <p class="temp"><%= meteos[0].current.temperature_2m.toFixed(1) %>°C</p>
          <p class="description"><%= traduireCodeMeteo(meteos[0].current.weather_code) %></p>
          <p class="ressenti">Ressenti <%= meteos[0].current.apparent_temperature.toFixed(1) %>°C</p>
          <p class="temp-journee">↓ <%= meteos[0].daily.temperature_2m_min[0].toFixed(0) %>° · ↑ <%= meteos[0].daily.temperature_2m_max[0].toFixed(0) %>°</p>
        </div>

        <div class="trains-panneau">

          <div class="trains-gare departs">
            <h3>Départs</h3>
            <% if (departsTrilportDepart.length > 0) { %>
            <% departsTrilportDepart.forEach((train, i) => { %>
            <div class="train-ligne <%= i === 0 ? 'principal' : 'secondaire' %>">
              <span class="train-heure"><%= train.heureFormatee %></span>
              <span class="dest-long"><%= train.destination %></span>
              <span class="dest-court"><%= train.destinationCourte %></span>
              <span class="train-countdown"><%= train.dansXMin %> min</span>
            </div>
            <% }) %>
            <% } else { %>
            <span class="statut-service <%= statutDeparts %>"><%= statutDeparts === "indisponible" ? "Indisponible" : statutDeparts === "attente" ? "En attente" : "Terminé" %></span>
            <% } %>
          </div>

          <div class="trains-gare arrivees">
            <h3>Arrivées</h3>
            <% if (arrivesTrilport.length > 0) { %>
            <% arrivesTrilport.forEach((train, i) => { %>
            <div class="train-ligne <%= i === 0 ? 'principal' : 'secondaire' %>">
              <span class="train-heure"><%= train.heureFormatee %></span>
              <span class="dest-long"><%= train.destination %></span>
              <span class="dest-court"><%= train.destinationCourte %></span>
              <span class="train-countdown"><%= train.dansXMin %> min</span>
            </div>
            <% }) %>
            <% } else { %>
            <span class="statut-service <%= statutArrivees %>"><%= statutArrivees === "indisponible" ? "Indisponible" : statutArrivees === "attente" ? "En attente" : "Terminé" %></span>
            <% } %>
          </div>

        </div>
      </div>
    </article>

    <%# Carte secondaire : Meaux %>
    <article class="carte carte-secondaire">
      <h2>Meaux</h2>
      <p class="temp"><%= meteos[1].current.temperature_2m.toFixed(0) %>°C</p>
      <p class="description"><%= traduireCodeMeteo(meteos[1].current.weather_code) %></p>
    </article>

  </section>
  <% } %>

  <%# === Section gym === %>
  <% if (creneaux && creneaux.length > 0) { %>
  <section class="gym">
    <h2>🏋️ Gym ce soir ?</h2>

    <div class="colonnes-creneaux">

      <div>
        <h3>Aller (Trilport → Meaux)</h3>
        <ul class="creneaux-liste">
          <% creneaux.filter((c) => c.direction === "aller").forEach((c) => { %>
          <li class="creneau <%= c.estMeilleur ? 'meilleur' : '' %>">
            <span class="heure"><%= c.realHeure %></span>
            <span class="resume"><%= c.resume %></span>
            <% if (c.statutTrain === "ok") { %>
            <ul>
              <% c.trainsAller.forEach((train) => { %>
              <li class="train-creneau">
                <span class="train-creneau-heure"><%= train.heureFormatee %></span>
                <span class="dest-long"><%= train.destination %></span>
                <span class="dest-court"><%= train.destinationCourte %></span>
                <span class="train-creneau-countdown"><%= train.dansXMin %> min</span>
              </li>
              <% }) %>
            </ul>
            <% } else if (c.statutTrain === "passe") { %>
            <span class="train-statut passe">🚫</span>
            <% } else if (c.statutTrain === "indisponible") { %>
            <span class="train-statut indisponible">Indisponible</span>
            <% } else { %>
            <span class="train-statut attente">· · ·</span>
            <% } %>
          </li>
          <% }) %>
        </ul>
      </div>
      <div>
        <h3>Retour (Meaux → Trilport)</h3>
        <ul class="creneaux-liste">
          <% creneaux.filter((c) => c.direction === "retour").forEach((c) => { %>
          <li class="creneau <%= c.estMeilleur ? 'meilleur' : '' %>">
            <span class="heure"><%= c.realHeure %></span>
            <span class="resume"><%= c.resume %></span>
            <% if (c.statutTrain === "ok") { %>
            <ul>
              <% c.trains.forEach((train) => { %>
              <li class="train-creneau">
                <span class="train-creneau-heure"><%= train.heureFormatee %></span>
                <span class="dest-long"><%= train.destination %></span>
                <span class="dest-court"><%= train.destinationCourte %></span>
                <span class="train-creneau-countdown"><%= train.dansXMin %> min</span>
              </li>
              <% }) %>
            </ul>
            <% } else if (c.statutTrain === "passe") { %>
            <span class="train-statut passe">🚫</span>
            <% } else if (c.statutTrain === "indisponible") { %>
            <span class="train-statut indisponible">Indisponible</span>
            <% } else { %>
            <span class="train-statut attente">· · ·</span>
            <% } %>
          </li>
          <% }) %>
        </ul>
      </div>

    </div>
  </section>
  <% } %>

  <% } %>

  <%# Bandeau trafic — fixé en bas de page %>
  <% if (niveauTrafic === "alerte" && detailAlerte) { %>
  <button class="bandeau-trafic alerte trafic-interactif" id="trafic-toggle" type="button" aria-expanded="false" aria-controls="trafic-details">
    <span class="bandeau-icone">🔴</span>
    <span><%= texteAlerte %></span>
    <span class="trafic-fleche" aria-hidden="true">ⓘ</span>
  </button>

  <section class="trafic-details" id="trafic-details" aria-label="Détails de la perturbation" hidden>
    <div class="trafic-details-entete">
      <h2>Détails de la perturbation</h2>
      <button class="trafic-details-fermer" type="button" aria-label="Fermer les détails">×</button>
    </div>
    <p><%= detailAlerte.details %></p>
    <% if (detailAlerte.trajet) { %>
    <p class="trafic-details-meta">Trajet : <%= detailAlerte.trajet %></p>
    <% } %>
    <% if (detailAlerte.debut) { %>
    <p class="trafic-details-meta">Du <%= formaterDatePerturbation(detailAlerte.debut) %> au <%= formaterDatePerturbation(detailAlerte.fin) %></p>
    <% } %>
  </section>

  <% } else { %>
  <div class="bandeau-trafic <%= niveauTrafic %>">

    <% if (niveauTrafic === "fluide") { %>
    <span class="bandeau-icone">🟢</span>
    <span>Trafic fluide</span>

    <% } else if (niveauTrafic === "info") { %>
    <span class="bandeau-icone">🟠</span>
    <span>Perturbation sur la ligne P</span>

    <% } else if (niveauTrafic === "alerte") { %>
    <span class="bandeau-icone">🔴</span>
    <span>
      <%= texteAlerte %> </span>
    <% } else { %>
    <span class="bandeau-icone">⚪</span>
    <span>Infos trafic temporairement indisponibles</span>
    <% } %>

  </div>
  <% } %>
  <% if (prochaineTravaux) { %>

  <button class="bandeau-travaux" id="travaux-toggle" type="button" aria-expanded="false" aria-controls="travaux-liste">
    <span>📅</span>
    <span>Travaux Ligne P</span>
    <span class="fleche">▶</span>
  </button>

  <div class="travaux-liste" id="travaux-liste">
    <% travauxFuturs.forEach((travaux) => { %>
    <div class="travaux-item">
      <%= travaux.dateDebut %> →
      <%= travaux.dateFin %>
      <% if (travaux.trajet) { %>
      • <%= travaux.trajet %>
      <% } %>
    </div>
    <% }) %>

  </div>

  <% } %>

  </main>

  <%# Script de bascule de thème %>
  <script src="/scripts/theme.js"></script>

  <%# Script de rafraîchissement %>
  <script src="/scripts/refresh.js"></script>

  <%# Scrpt pour basculer la liste de travaux %>
  <script src="/scripts/travaux.js"></script>

  <%# Script pour afficher le détail des alertes trafic %>
  <script src="/scripts/alert-details.js"></script>
</body>

</html>
